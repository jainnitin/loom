{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Loom",
  "version": "1.0.5",
  "identifier": "com.mainpy.loom",
  "build": {
    "beforeDevCommand": "npm run dev:vite",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:vite",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Loom",
        "width": 1200,
        "height": 800,
        "minWidth": 400,
        "minHeight": 300,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": { "x": 20, "y": 20 },
        "backgroundColor": "#262624",
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "category": "DeveloperTool",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "hardenedRuntime": true
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["claude-viewer"]
      }
    }
  }
}
